# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=tilligo
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=tilligo
POSTGRES_PORT=5436

# ── Redis ────────────────────────────────────────────────
REDIS_PORT=6381

# ── API ──────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=change-me-in-production
ACK_TOKEN_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:3000

# ── SMTP (leave blank for mock/json transport) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Email Configuration ──────────────────────────────────
EMAIL_DOMAIN=tilli.pro
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Tilli-go
EMAIL_FALLBACK_TEAM=ops

# ── Microsoft OAuth (Azure AD / Entra ID) ────────────────
# Leave blank to disable Microsoft sign-in
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback
TOKEN_ENCRYPTION_KEY=

# ── Microsoft Graph Email (optional, replaces SMTP) ──────
MICROSOFT_MAIL_ENABLED=false
MICROSOFT_MAIL_FROM=
