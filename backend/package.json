{
  "name": "tilli-go-backend",
  "version": "1.0.0",
  "description": "Tilli-go API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "@prisma/client": "^5.20.0",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.7",
    "prisma": "^5.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
