{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@fixtures/*": ["src/fixtures/*"],
      "@page-objects/*": ["src/page-objects/*"],
      "@helpers/*": ["src/helpers/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
