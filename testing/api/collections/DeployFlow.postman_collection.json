{
  "info": {
    "name": "DeployFlow API",
    "_postman_id": "df-collection-001",
    "description": "Full API test suite for DeployFlow. Run folders in order (00–08). Uses environment variables for chaining.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-attach Authorization header for protected endpoints",
          "const noAuthPaths = ['/health', '/api/auth/register', '/api/auth/login', '/api/acknowledge'];",
          "const requestUrl = pm.request.url.toString();",
          "if (!noAuthPaths.some(p => requestUrl.includes(p))) {",
          "  const token = pm.environment.get('token');",
          "  if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "  }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 — Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has status ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
